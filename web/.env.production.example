# Production build-time environment variables for `npm run build`.
# Vite inlines these at build time — they are NOT read at runtime on Gitee Pages.
#
# Option A: copy to `.env.production.local` (gitignored) before building:
#   cp .env.production.example .env.production.local
#   # edit .env.production.local with real values
#
# Option B: export in the shell before `npm run build`:
#   export VITE_SUPABASE_URL=...
#   export VITE_SUPABASE_ANON_KEY=...
#
# Local dev: copy `.env.local` from the desktop-pet-cc project (same Supabase project).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
